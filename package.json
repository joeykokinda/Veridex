{
  "name": "veridex",
  "version": "1.0.0",
  "description": "On-chain identity for AI agents - ETHDenver 2026",
  "scripts": {
    "setup:validate": "node scripts/setup/validate.js",
    "setup:convert-key": "node scripts/setup/convert-hedera-key.js",
    "setup:generate-wallet": "node scripts/setup/generate-agent-wallet.js",
    "setup:check-balance": "node scripts/setup/check-balance.js",
    "deploy": "hardhat run scripts/deploy.js --network hedera-testnet",
    "deploy:marketplace": "hardhat run scripts/deploy-marketplace.js --network hedera-testnet",
    "register": "node scripts/agent/register.js",
    "register:all": "node scripts/agent/register-all-agents.js",
    "fund:all": "node scripts/agent/fund-all-agents-hedera.js",
    "topup:all": "node scripts/agent/topup-agents.js",
    "quick-register": "node scripts/agent/quick-register.js",
    "unregister": "node scripts/agent/unregister.js",
    "status": "node scripts/agent/check-status.js",
    "update-stats": "node scripts/agent/update-stats.js",
    "orchestrator": "node orchestrator/index.js",
    "dev:app": "cd app && npm run dev",
    "demo": "./demo.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "test": "hardhat test"
  },
  "keywords": [
    "hedera",
    "ai-agents",
    "blockchain",
    "ethdenver"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hashgraph/sdk": "^2.80.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "express": "^4.18.2",
    "hardhat": "^2.20.1",
    "openai": "^4.104.0"
  }
}
