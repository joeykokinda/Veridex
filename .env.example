# ==============================================================================
# HEDERA TESTNET CREDENTIALS
# ==============================================================================

# Your Hedera testnet account ID and private key
# Get from: https://portal.hedera.com → Create testnet account
DEPLOYER_ACCOUNT_ID=0.0.XXXXXX
DEPLOYER_PRIVATE_KEY=0x...

# ==============================================================================
# DEPLOYED CONTRACT ADDRESSES (already deployed — do not redeploy)
# ==============================================================================

AGENT_IDENTITY_CONTRACT=0x0874571bAfe20fC5F36759d3DD3A6AD44e428250
AGENT_MARKETPLACE_CONTRACT=0x46e12242aEa85a1fa2EA5C769cd600fA64A434C6
CONTENT_REGISTRY_CONTRACT=0x031bbBBCCe16EfBb289b3f6059996D0e9Bba5BcC

# ==============================================================================
# AI/LLM (required for marketplace simulation agents)
# ==============================================================================

OPENAI_API_KEY=sk-proj-...

# ==============================================================================
# TELEGRAM ALERTS (optional — highly recommended for demo)
# ==============================================================================

# 1. Message @BotFather on Telegram → /newbot → name it "Veridex Alerts"
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=

# 3. Start a chat with your bot, then get your chat ID:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → look for "id" in "chat"
TELEGRAM_CHAT_ID=

# ==============================================================================
# SECRETS VAULT (Layer 1)
# ==============================================================================

# 32-byte hex key for AES-256-GCM encryption of stored secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If not set, secrets are lost on server restart.
VAULT_ENCRYPTION_KEY=

# ==============================================================================
# DATABASE
# ==============================================================================

# SQLite path for agent logs, alerts, policies, earnings
DATABASE_PATH=./orchestrator/veridex.db

# ==============================================================================
# SERVER
# ==============================================================================

ORCHESTRATOR_PORT=3001

# ==============================================================================
# FRONTEND (Next.js)
# ==============================================================================

NEXT_PUBLIC_CONTRACT_ADDRESS=0x0874571bAfe20fC5F36759d3DD3A6AD44e428250
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x46e12242aEa85a1fa2EA5C769cd600fA64A434C6
NEXT_PUBLIC_IDENTITY_HEDERA_ID=0.0.7992394
NEXT_PUBLIC_MARKETPLACE_HEDERA_ID=0.0.7992397

# Vercel deployment: set ORCHESTRATOR_URL in Vercel dashboard
# ORCHESTRATOR_URL=https://your-server:3001

# ==============================================================================
# QUICK START
# ==============================================================================
#
# 1. cp .env.example .env
# 2. Fill in DEPLOYER_ACCOUNT_ID, DEPLOYER_PRIVATE_KEY, OPENAI_API_KEY
# 3. node orchestrator/index.js          ← backend on :3001
# 4. node bots/research-bot.js &         ← benign activity
# 5. node bots/trading-bot.js &          ← earnings splits
# 6. node bots/rogue-bot.js &            ← blocked attacks (demo WOW moment)
# 7. cd app && npm run dev               ← frontend on :3000
# 8. Open http://localhost:3000/monitor
#
# ==============================================================================
